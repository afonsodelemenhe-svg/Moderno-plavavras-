const checkBadWords = require("./modules/filters/filter");
const punish = require("./modules/actions/punish");
const log = require("./modules/actions/logs");

client.on("messageCreate", async (message) => {
  if (message.author.bot) return;

  if (checkBadWords(message)) {
    await punish(message);
    await log(message, client);
  }
});
